# ==============================================================================
# Database Services Environment Configuration - EXAMPLE
# ==============================================================================
# ------------------------------------------------------------------------------
# MySQL Configuration
# ------------------------------------------------------------------------------
# MySQL root password (CHANGE THIS!)
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# MySQL application user
MYSQL_USER=app_user

# MySQL application user password (CHANGE THIS!)
MYSQL_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# MySQL database name
MYSQL_DATABASE=myapp_db

# MySQL port (default: 3306)
MYSQL_PORT=3306

# ------------------------------------------------------------------------------
# PostgreSQL Configuration
# ------------------------------------------------------------------------------
# PostgreSQL superuser name
POSTGRES_ROOT_USER=postgres

# PostgreSQL superuser password (CHANGE THIS!)
POSTGRES_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# PostgreSQL application user
POSTGRES_USER=app_user

# PostgreSQL application user password (CHANGE THIS!)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# PostgreSQL database name
POSTGRES_DB=myapp_db

# PostgreSQL port (default: 5432)
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# Redis Configuration
# ------------------------------------------------------------------------------
# Redis authentication password (CHANGE THIS!)
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis port (default: 6379)
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# Data Directory Configuration
# ------------------------------------------------------------------------------
# Absolute path where database data will be stored
# Ensure this directory has proper permissions and sufficient disk space
DATA_DIR=/var/lib/dbservices
